<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="GorodTv.Tv.Controls.TvDialogPopup"
             x:TypeArguments="x:Boolean"
             CanBeDismissedByTappingOutsideOfPopup="False"
             Padding="0" Margin="0">

    <!-- карточка по центру тёмного полупрозрачного фона --> 
    <Border BackgroundColor="#161B24" StrokeThickness="0" StrokeShape="RoundRectangle 24"
            WidthRequest="640" HorizontalOptions="Center" VerticalOptions="Center"
            Padding="40,36">
        <VerticalStackLayout Spacing="20">

            <Border x:Name="IconCircle" BackgroundColor="#1E2A3D" StrokeThickness="0"
                    StrokeShape="RoundRectangle 36" WidthRequest="72" HeightRequest="72"
                    HorizontalOptions="Center">
                <Label x:Name="IconLabel" FontFamily="MaterialSymbols" FontSize="36"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>

            <Label x:Name="TitleLabel" FontFamily="OnestBold" FontSize="26"
                   TextColor="White" HorizontalTextAlignment="Center" />

            <Label x:Name="MessageLabel" FontFamily="Onest" FontSize="18"
                   TextColor="#B9C4D4" HorizontalTextAlignment="Center" />

            <!-- кнопки: фокусируемые под пульт -->
            <Grid x:Name="ButtonsGrid" ColumnDefinitions="*,*" ColumnSpacing="16" Margin="0,8,0,0">
                <Button x:Name="CancelButton" Grid.Column="0" Text="Отмена"
                        Style="{StaticResource TvDialogCancel}" Clicked="OnCancel" IsVisible="False" />
                <Button x:Name="OkButton" Grid.Column="1" Text="ОК"
                        Style="{StaticResource TvDialogOk}" Clicked="OnOk" />
            </Grid>
        </VerticalStackLayout>
    </Border>

</toolkit:Popup>