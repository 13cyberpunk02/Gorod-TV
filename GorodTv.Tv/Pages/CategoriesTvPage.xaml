<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GorodTV.Core.ViewModels;assembly=GorodTV.Core"
             xmlns:models="clr-namespace:GorodTV.Core.Models;assembly=GorodTV.Core"
             xmlns:ctrl="clr-namespace:GorodTv.Tv.Controls"
             x:Class="GorodTv.Tv.Pages.CategoriesTvPage"
             x:DataType="vm:CategoriesViewModel"
             x:Name="Page"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0B0E13">

    <Grid ColumnDefinitions="96,*">

        <!-- САЙДБАР (общий контрол) -->
        <ctrl:TvSidebar Grid.Column="0" />

        <!-- КОНТЕНТ -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*" Padding="40,28,40,28" RowSpacing="20">
            <VerticalStackLayout Grid.Row="0" Spacing="4">
                <Label Text="ДОБРЫЙ ВЕЧЕР" FontFamily="OnestBold" FontSize="13" TextColor="#5B6B82" />
                <Label Text="Выберите категорию" FontFamily="OnestBold" FontSize="30" TextColor="White" />
            </VerticalStackLayout>

            <!-- карточки строятся из code-behind в этот контейнер -->
            <ScrollView Grid.Row="1">
                <FlexLayout x:Name="CategoriesHost" Wrap="Wrap"
                            JustifyContent="Start" AlignContent="Start" />
            </ScrollView>
        </Grid>
    </Grid>

</ContentPage>