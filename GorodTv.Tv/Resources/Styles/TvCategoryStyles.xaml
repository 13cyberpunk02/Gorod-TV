<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- кнопка сайдбара (иконка) -->
    <Style x:Key="TvNavButton" TargetType="Button">
        <Setter Property="FontFamily" Value="MaterialSymbols" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor" Value="#8A94A6" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="WidthRequest" Value="52" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="Transparent" />
                            <Setter Property="TextColor" Value="#8A94A6" />
                            <Setter Property="BorderColor" Value="Transparent" />
                            <Setter Property="BorderWidth" Value="0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Focused">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="TextColor" Value="White" />
                            <Setter Property="BorderColor" Value="#9DC1FF" />
                            <Setter Property="BorderWidth" Value="2" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- прозрачная фокус-кнопка поверх карточки категории -->
    <Style x:Key="TvCardFocus" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="16" />
    </Style>

</ResourceDictionary>