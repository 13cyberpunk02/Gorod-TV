<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- клавиша экранной клавиатуры -->
    <Style x:Key="TvKey" TargetType="Button">
        <Setter Property="Margin" Value="3" />
        <Setter Property="BackgroundColor" Value="#1A2230" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OnestBold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="#1A2230" />
                            <Setter Property="BorderColor" Value="Transparent" />
                            <Setter Property="BorderWidth" Value="0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Focused">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                            <Setter Property="BorderColor" Value="#FFFFFF" />
                            <Setter Property="BorderWidth" Value="3" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- кнопка «Войти» (красная) -->
    <Style x:Key="TvPrimaryKey" TargetType="Button">
        <Setter Property="Margin" Value="3" />
        <Setter Property="BackgroundColor" Value="{StaticResource Live}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OnestBold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="HeightRequest" Value="44" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="BorderColor" Value="Transparent" />
                            <Setter Property="BorderWidth" Value="0" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Focused">
                        <VisualState.Setters>
                            <Setter Property="BorderColor" Value="#FFFFFF" />
                            <Setter Property="BorderWidth" Value="3" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

</ResourceDictionary>