<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GorodTV.Resources.Styles.IL_Styles">
    <!-- ===== Палитра ===== -->
    <Color x:Key="Primary">#1B66E5</Color>
    <Color x:Key="PrimaryDark">#1453BE</Color>
    <Color x:Key="Live">#E5342B</Color>
    <Color x:Key="Background">#F5F7FA</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="TextPrimary">#15191E</Color>
    <Color x:Key="TextSecondary">#8A94A6</Color>
    <Color x:Key="Stroke">#E3E8F0</Color>
    <Color x:Key="FieldBg">#F8FAFD</Color>

    <!-- ===== Иконки Material Symbols (codepoints) ===== -->
    <x:String x:Key="IconBadge">&#xea67;</x:String>
    <!-- badge -->
    <x:String x:Key="IconLock">&#xe897;</x:String>
    <!-- lock -->
    <x:String x:Key="IconVisibilityOff">&#xe8f5;</x:String>
    <!-- visibility_off -->
    <x:String x:Key="IconVisibility">&#xe8f4;</x:String>
    <!-- visibility -->
    <x:String x:Key="IconTv">&#xe63b;</x:String>
    <!-- smart_display -->

    <!-- ===== Типографика ===== -->
    <Style x:Key="H1" TargetType="Label">
        <Setter Property="FontFamily" Value="OnestBold" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="Subtitle" TargetType="Label">
        <Setter Property="FontFamily" Value="Onest" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OnestMedium" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- ===== Поле ввода (рамка) ===== -->
    <Style x:Key="InputBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource FieldBg}" />
        <Setter Property="Stroke" Value="{StaticResource Stroke}" />
        <Setter Property="StrokeThickness" Value="1.5" />
        <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Padding" Value="16,0" />
    </Style>

    <Style x:Key="InputEntry" TargetType="Entry">
        <Setter Property="FontFamily" Value="OnestMedium" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>

    <!-- ===== Основная кнопка ===== -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OnestBold" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Shadow">
            <Shadow Brush="{StaticResource Primary}" Opacity="0.35" Radius="18" Offset="0,8" />
        </Setter>
    </Style>

    <!-- Иконка из Material Symbols -->
    <Style x:Key="Icon" TargetType="Label">
        <Setter Property="FontFamily" Value="MaterialSymbols" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="VerticalOptions" Value="Center" />
    </Style>
</ResourceDictionary>