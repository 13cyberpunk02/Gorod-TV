<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:GorodTV.Core.Converters;assembly=GorodTV.Core"
             xmlns:local="clr-namespace:GorodTV"
             x:Class="GorodTV.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/IL_Styles.xaml" />                
            </ResourceDictionary.MergedDictionaries>
            <conv:InvertedBoolConverter x:Key="InvertBool" />
            <conv:FlexibleBoolConverter x:Key="FlexibleBool" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
